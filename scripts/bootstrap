#!/usr/bin/env bash
set -euo pipefail

# Bootstrap deterministic dependencies for LunaLighthouse mobile development.
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_DIR="$ROOT_DIR/luna_lighthouse"

if [[ ! -d "$APP_DIR" ]]; then
  echo "[bootstrap] Missing app directory: $APP_DIR" >&2
  exit 1
fi

"$ROOT_DIR/scripts/doctor"

pushd "$APP_DIR" >/dev/null

# Pull Flutter/Dart dependencies for application and generator tooling.
flutter pub get

# Pull JS dev tooling dependencies used by release/version scripts. The app is
# nested below the git root, so package lifecycle hooks such as Husky prepare
# are intentionally skipped here.
npm ci --ignore-scripts

# Install Android fastlane dependencies.
pushd android >/dev/null
bundle install
popd >/dev/null

# Install Apple fastlane dependencies on macOS only.
if [[ "$(uname -s)" == "Darwin" ]]; then
  pushd ios >/dev/null
  bundle install
  popd >/dev/null
fi

popd >/dev/null

echo "[bootstrap] LunaLighthouse mobile dependencies are ready."
