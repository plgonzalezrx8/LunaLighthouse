#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LCOV_FILE="${1:-$ROOT_DIR/luna_lighthouse/coverage/lcov.info}"
MIN_COVERAGE="${2:-2}"

if [[ ! -f "$LCOV_FILE" ]]; then
  echo "[check-flutter-coverage] Missing LCOV file: $LCOV_FILE" >&2
  exit 1
fi

coverage="$(
  awk -F: '
    /^LF:/ { found += $2 }
    /^LH:/ { hit += $2 }
    END {
      if (found == 0) {
        print "0.00 0 0"
      } else {
        printf "%.2f %d %d\n", hit * 100 / found, hit, found
      }
    }
  ' "$LCOV_FILE"
)"

percent="$(echo "$coverage" | awk '{print $1}')"
hit="$(echo "$coverage" | awk '{print $2}')"
found="$(echo "$coverage" | awk '{print $3}')"

echo "[check-flutter-coverage] Flutter line coverage: ${percent}% (${hit}/${found}), minimum: ${MIN_COVERAGE}%"

awk -v actual="$percent" -v minimum="$MIN_COVERAGE" 'BEGIN { exit(actual + 0 >= minimum + 0 ? 0 : 1) }'
